# PostgreSQL credentials
POSTGRES_USER=conference
POSTGRES_PASSWORD=changeme
POSTGRES_DB=conferencedb

# .NET API — connection string must match the credentials above
ConnectionStrings__conferencedb=Host=postgres;Port=5432;Database=conferencedb;Username=conference;Password=changeme

# JWT settings — change SecretKey to a random string of at least 32 characters
Jwt__Key=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_32_CHARS_MIN
Jwt__Issuer=ConferenceApp
Jwt__Audience=ConferenceApp
