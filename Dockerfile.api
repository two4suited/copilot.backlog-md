# Build stage
FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src

# Copy solution and project files for layer-cached restore
COPY Sessionize.sln ./
COPY Sessionize.Api/Sessionize.Api.csproj Sessionize.Api/
COPY Sessionize.Models/Sessionize.Models.csproj Sessionize.Models/
COPY Sessionize.ServiceDefaults/Sessionize.ServiceDefaults.csproj Sessionize.ServiceDefaults/

RUN dotnet restore Sessionize.Api/Sessionize.Api.csproj

# Copy remaining source and publish
COPY Sessionize.Api/ Sessionize.Api/
COPY Sessionize.Models/ Sessionize.Models/
COPY Sessionize.ServiceDefaults/ Sessionize.ServiceDefaults/

RUN dotnet publish Sessionize.Api/Sessionize.Api.csproj \
    -c Release \
    -o /app/publish \
    --no-restore

# Runtime stage
FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS runtime
WORKDIR /app

ENV ASPNETCORE_URLS=http://+:8080
EXPOSE 8080

COPY --from=build /app/publish .

ENTRYPOINT ["dotnet", "Sessionize.Api.dll"]
